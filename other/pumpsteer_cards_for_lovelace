##### PumpSteer Lovelace Cards ######################################################################################

type: sections
sections:
  - type: grid
    cards:
      - type: vertical-stack
        cards:
          - type: glance
            show_name: true
            show_icon: true
            show_state: true
            columns: 3
            entities:
              - entity: sensor.pumpsteer_operating_mode
                name: Mode
              - entity: sensor.pumpsteer_price_category
                name: Price
              - entity: sensor.pumpsteer_is_saving
                name: Saving
                icon: mdi:piggy-bank
      - type: vertical-stack
        cards:
          - type: entities
            title: Settings
            show_header_toggle: false
            entities:
              - entity: number.pumpsteer_target_temperature
                name: Target Temperature
                icon: mdi:thermometer
              - entity: number.pumpsteer_saving_level
                name: Aggressiveness (0 = Off, 5 = Max)
                icon: mdi:lightning-bolt-circle
              - entity: number.pumpsteer_summer_mode_threshold
                name: Summer Threshold
                icon: mdi:weather-sunny
              - entity: number.pumpsteer_house_thermal_mass
                name: House Thermal Mass
                icon: mdi:home-thermometer
              - entity: switch.pumpsteer_notifications
                name: Notifications
              - entity: switch.pumpsteer_ohmigo_push
                name: Ohmigo Push
              - entity: switch.pumpsteer_preheat_boost
              - entity: datetime.pumpsteer_holiday_start
                name: Holiday Start
              - entity: datetime.pumpsteer_holiday_end
                name: Holiday End
              - entity: switch.pumpsteer_holiday_mode
                name: Holiday Mode
              - entity: sensor.pumpsteer_thermal_outlook
      - type: entities
        title: Status Details
        show_header_toggle: false
        entities:
          - entity: sensor.pumpsteer_price_thresholds
            name: Price Thresholds (P30/P80)
            icon: mdi:chart-bell-curve
          - entity: sensor.pumpsteer_temperature_difference
            name: Indoor vs Target Difference
            icon: mdi:delta
          - entity: sensor.pumpsteer_fake_temp_delta
            name: Virtual vs Real Outdoor Temp
            icon: mdi:swap-horizontal-bold
          - entity: sensor.pumpsteer_brake_factor
            name: Brake Factor
            icon: mdi:car-brake-alert
          - type: attribute
            entity: sensor.pumpsteer
            attribute: heating_demand_c
            name: Heating Demand
            icon: mdi:fire
