            icon: mdi:chart-bell-curve
          - type: attribute
            entity: sensor.pumpsteer
            attribute: p80
            name: Price P80 Today
            suffix: SEK/kWh
            icon: mdi:chart-bell-curve
          - entity: sensor.elpris_spot_avgifter
