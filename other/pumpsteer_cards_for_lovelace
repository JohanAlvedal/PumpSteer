            suffix: °C
            icon: mdi:home-thermometer
          - type: attribute
            entity: sensor.pumpsteer
            attribute: outdoor_temperature
            name: Outdoor Temperature
            suffix: °C
            icon: mdi:thermometer
          - type: attribute
            entity: sensor.pumpsteer
