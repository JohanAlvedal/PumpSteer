        name: 📈 Offset-utveckling (24h)
        hours_to_show: 24
        points_per_hour: 4
        line_width: 3
        font_size: 75
        animate: true
        show:
          labels: false
          legend: true
          icon: false
        entities:
          - entity: sensor.pumpsteer
            name: Outdoor
            show_state: true
          - entity: sensor.pumpsteer_fake_temp_delta
            name: Brake factor
            show_state: true
  - type: grid
    cards:
      - type: entities
        title: PumpSteer Data
        entities:
          - type: attribute
            entity: sensor.pumpsteer
            attribute: status
            name: Status
            icon: mdi:check-circle
          - type: attribute
            entity: sensor.pumpsteer
            attribute: mode
            name: Mode
            icon: mdi:cog
          - type: attribute
            entity: sensor.pumpsteer
            attribute: price_category
            name: Price Category
            icon: mdi:tag
          - entity: sensor.pumpsteer
            icon: mdi:thermometer-chevron-down
            name: Virtual Outdoor Temperature
            secondary_info: last-changed
          - type: attribute
            entity: sensor.pumpsteer
            attribute: indoor_temperature
